# Configuration base de données
# IMPORTANT : Ne JAMAIS utiliser root en production — créer un compte dédié avec privilèges limités
DB_HOST=localhost
DB_NAME=ForbachEnRose
DB_USER=fer_app
DB_PASS=CHANGEZ_MOI_mot_de_passe_fort

# Clé de chiffrement AES-256-GCM (48 octets en base64)
# Générer avec : php -r "echo base64_encode(random_bytes(48));"
ENCRYPTION_KEY=CHANGEZ_MOI_generer_avec_php_random_bytes

# (Optionnel) URL de base de l'application — empêche le Host header injection
# APP_URL=https://forbachenrose.com
