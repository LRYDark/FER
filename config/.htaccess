# Bloquer l'accès à tous les fichiers cachés (.env, .htaccess, etc.)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Bloquer aussi les fichiers sensibles par extension
# 🔒 [SEC-03] .json ajouté pour protéger token.json (CWE-538)
<FilesMatch "\.(env|log|bak|sql|old|txt|json)$">
    Require all denied
</FilesMatch>