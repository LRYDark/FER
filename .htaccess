# Bloquer l'accès aux fichiers sensibles
<FilesMatch "\.(env|log|bak|sql|old)$">
    Require all denied
</FilesMatch>

# Bloquer token.json (OAuth Gmail)
<Files "token.json">
    Require all denied
</Files>

# Bloquer les fichiers cachés
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Bloquer les fichiers de migration
<FilesMatch "^migrate">
    Require all denied
</FilesMatch>

# Pages d'erreur personnalisées
ErrorDocument 403 /FER/errors/403.php
ErrorDocument 404 /FER/errors/404.php
ErrorDocument 500 /FER/errors/500.php
ErrorDocument 503 /FER/errors/503.php

# URLs propres : permet d'accéder sans .php
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ $1.php [L,QSA]

######### Generated by Lwspanel #########
######### Ne pas modifier / Don't touch #########

# Redirections https forbachenrose.com
RewriteEngine On
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteCond %{HTTPS} !on
RewriteCond %{HTTP_HOST} ^(?:www\.)?forbachenrose\.com(?:.*)$ [nc]
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [redirect=301,L]

######### End Generated by Lwspanel #########
