# Bloquer l'accès aux fichiers sensibles
<FilesMatch "\.(env|log|bak|sql|old)$">
    Require all denied
</FilesMatch>

# Bloquer token.json (OAuth Gmail)
<Files "token.json">
    Require all denied
</Files>

# Bloquer les fichiers cachés
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Bloquer les fichiers de migration
<FilesMatch "^migrate">
    Require all denied
</FilesMatch>
